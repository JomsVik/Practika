<Window x:Class="ShoeStore.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация нового пользователя" 
        Height="580" Width="450"
        WindowStartupLocation="CenterScreen"
        FontFamily="Times New Roman"
        Background="White"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Регистрация" FontSize="24" 
                   FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,25"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <TextBlock Text="ФИО:" FontSize="14" Margin="0,0,0,5"/>
            <TextBox x:Name="txtFullName" Height="35" Padding="5" FontSize="14"/>
            <TextBlock Text="минимум 5 символов, фамилия и имя" 
                       FontSize="11" Foreground="Gray" Margin="0,3,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,15">
            <TextBlock Text="Логин:" FontSize="14" Margin="0,0,0,5"/>
            <TextBox x:Name="txtLogin" Height="35" Padding="5" FontSize="14"/>
            <TextBlock Text="минимум 3 символа (буквы, цифры, точка, дефис)" 
                       FontSize="11" Foreground="Gray" Margin="0,3,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,15">
            <TextBlock Text="Пароль:" FontSize="14" Margin="0,0,0,5"/>
            <PasswordBox x:Name="txtPassword" Height="35" Padding="5" FontSize="14"/>
            <TextBlock Text="минимум 6 символов" 
                       FontSize="11" Foreground="Gray" Margin="0,3,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Margin="0,0,0,15">
            <TextBlock Text="Подтверждение пароля:" FontSize="14" Margin="0,0,0,5"/>
            <PasswordBox x:Name="txtConfirmPassword" Height="35" Padding="5" FontSize="14"/>
            <TextBlock Text="должен совпадать с паролем" 
                       FontSize="11" Foreground="Gray" Margin="0,3,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,25,0,20">
            <Button x:Name="btnRegister" Content="Зарегистрироваться" Width="160" Height="40" 
                    Background="#00FA9A" FontWeight="Bold" FontSize="14"
                    Margin="0,0,15,0" Click="btnRegister_Click"/>
            <Button x:Name="btnCancel" Content="Отмена" Width="120" Height="40" 
                    Background="#7FFF00" FontSize="14" Click="btnCancel_Click"/>
        </StackPanel>


        <TextBlock Grid.Row="7" x:Name="txtStatus" Foreground="Red" 
                   HorizontalAlignment="Center" Margin="0,10" FontSize="14"/>

        <TextBlock Grid.Row="5" VerticalAlignment="Top" HorizontalAlignment="Center" FontSize="14" Margin="0,73,0,0" Grid.RowSpan="3">
            <Run Text="Уже есть аккаунт? "/>
            <Hyperlink Click="LoginLink_Click">Войти</Hyperlink>
        </TextBlock>
    </Grid>
</Window>