<Window x:Class="ShoeStore.Views.CartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Корзина" Height="500" Width="700"
        WindowStartupLocation="CenterOwner"
        FontFamily="Times New Roman"
        Background="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Корзина" FontSize="20" 
                   FontWeight="Bold" Margin="0,0,0,20"/>

        <ListView Grid.Row="1" x:Name="listCart" 
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  Margin="0,0,0,10">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Товар" Width="200">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Image Source="{Binding ImagePath}" Width="40" Height="40" Margin="0,0,5,0"/>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="Артикул" Width="80" 
                                    DisplayMemberBinding="{Binding Article}"/>

                    <GridViewColumn Header="Цена" Width="80" 
                                    DisplayMemberBinding="{Binding PriceWithDiscount, StringFormat={}{0:N0} ₽}"/>

                    <GridViewColumn Header="Кол-во" Width="100">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="-" Width="25" Click="DecreaseQuantity_Click"
                                            Tag="{Binding ProductId}"/>
                                    <TextBlock Text="{Binding Quantity}" Width="30" 
                                               TextAlignment="Center" VerticalAlignment="Center"/>
                                    <Button Content="+" Width="25" Click="IncreaseQuantity_Click"
                                            Tag="{Binding ProductId}"/>
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <GridViewColumn Header="Сумма" Width="80" 
                                    DisplayMemberBinding="{Binding TotalPrice, StringFormat={}{0:N0} ₽}"/>

                    <GridViewColumn Header="Удалить" Width="50">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="X" Width="30" Background="Red" Foreground="White"
                                        Click="RemoveFromCart_Click" Tag="{Binding ProductId}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10">
            <TextBlock Text="Итого:" FontSize="16" FontWeight="Bold" Margin="0,0,10,0"/>
            <TextBlock x:Name="txtTotal" FontSize="16" FontWeight="Bold" Foreground="Green"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
            <Button x:Name="btnCheckout" Content="Оформить заказ" Width="150" Height="40" 
                    Background="#00FA9A" FontWeight="Bold" Margin="0,0,10,0" Click="btnCheckout_Click"/>
            <Button x:Name="btnContinue" Content="Продолжить покупки" Width="150" Height="40" 
                    Background="#7FFF00" Click="btnContinue_Click"/>
        </StackPanel>
    </Grid>
</Window>