<Window x:Class="ShoeStore.Views.ProductDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Детали товара" Height="600" Width="800"
        WindowStartupLocation="CenterOwner"
        FontFamily="Times New Roman"
        Background="White"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Детали товара" FontSize="24" 
                   FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Левая колонка - изображение -->
                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                    <Border Background="#F0F0F0" BorderBrush="Gray" BorderThickness="1" 
                            CornerRadius="5" Padding="10" Height="300">
                        <Image Source="{Binding ImagePath}" Stretch="Uniform" MaxHeight="280"/>
                    </Border>
                </StackPanel>

                <!-- Правая колонка - информация -->
                <StackPanel Grid.Column="1">
                    <Border Background="#F9F9F9" Padding="15" CornerRadius="5">
                        <StackPanel>
                            <TextBlock Text="Артикул:" FontSize="14" FontWeight="Bold" Foreground="#555"/>
                            <TextBlock Text="{Binding Article}" FontSize="18" Margin="0,0,0,15"/>

                            <TextBlock Text="Наименование:" FontSize="14" FontWeight="Bold" Foreground="#555"/>
                            <TextBlock Text="{Binding Name}" FontSize="22" FontWeight="Bold" Margin="0,0,0,15" TextWrapping="Wrap"/>

                            <TextBlock Text="Категория:" FontSize="14" FontWeight="Bold" Foreground="#555"/>
                            <TextBlock Text="{Binding Category}" FontSize="16" Margin="0,0,0,15"/>

                            <TextBlock Text="Цена:" FontSize="14" FontWeight="Bold" Foreground="#555"/>
                            <TextBlock Text="{Binding Price, StringFormat={}{0:N0} ₽}" 
                                       FontSize="24" FontWeight="Bold" Foreground="Green"/>

                            <TextBlock Text="Скидка:" FontSize="14" FontWeight="Bold" Foreground="#555" Margin="0,10,0,0"/>
                            <TextBlock Text="{Binding Discount, StringFormat={}{0}%}" 
                                       FontSize="16" Foreground="Red"/>

                            <TextBlock Text="Наличие:" FontSize="14" FontWeight="Bold" Foreground="#555" Margin="0,10,0,0"/>
                            <TextBlock Text="{Binding Quantity, StringFormat={}{0} шт.}" 
                                       FontSize="16"/>

                            <TextBlock Text="Производитель:" FontSize="14" FontWeight="Bold" Foreground="#555" Margin="0,10,0,0"/>
                            <TextBlock Text="{Binding Manufacturer}" FontSize="16" Margin="0,0,0,15"/>

                            <TextBlock Text="Поставщик:" FontSize="14" FontWeight="Bold" Foreground="#555"/>
                            <TextBlock Text="{Binding Supplier}" FontSize="16" Margin="0,0,0,15"/>

                            <TextBlock Text="Описание:" FontSize="14" FontWeight="Bold" Foreground="#555"/>
                            <TextBlock Text="{Binding Description}" FontSize="14" 
                                       TextWrapping="Wrap" Margin="0,0,0,15"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
            <Button x:Name="btnAddToCart" Content="🛒 Добавить в корзину" Width="180" Height="40" 
                    Background="#00FA9A" FontWeight="Bold" FontSize="14"
                    Margin="0,0,15,0" Click="btnAddToCart_Click"/>
            <Button x:Name="btnBack" Content="◀ Назад в каталог" Width="150" Height="40" 
                    Background="#7FFF00" FontSize="14" Click="btnBack_Click"/>
        </StackPanel>
    </Grid>
</Window>