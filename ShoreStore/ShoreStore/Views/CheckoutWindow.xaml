<Window x:Class="ShoeStore.Views.CheckoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Оформление заказа" Height="500" Width="500"
        WindowStartupLocation="CenterOwner"
        FontFamily="Times New Roman"
        Background="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Оформление заказа" FontSize="20" 
                   FontWeight="Bold" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <TextBlock Text="ФИО получателя:" FontSize="14" Margin="0,0,0,5"/>
            <TextBox x:Name="txtFullName" Height="35" Padding="5" FontSize="14"
                     IsEnabled="False"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,15">
            <TextBlock Text="Пункт выдачи:" FontSize="14" Margin="0,0,0,5"/>
            <ComboBox x:Name="cmbPickupPoints" Height="35" FontSize="14" 
                      DisplayMemberPath="Address" SelectedIndex="0"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,15">
            <TextBlock Text="Телефон:" FontSize="14" Margin="0,0,0,5"/>
            <TextBox x:Name="txtPhone" Height="35" Padding="5" FontSize="14"/>
        </StackPanel>

        <Border Grid.Row="4" Background="#F0F0F0" Padding="10" CornerRadius="5" Margin="0,10,0,10">
            <StackPanel>
                <TextBlock Text="Состав заказа:" FontWeight="Bold" Margin="0,0,0,5"/>
                <ListView x:Name="listOrderItems" Height="100" ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Name}" Width="150"/>
                                <TextBlock Text="{Binding Quantity}" Width="50" TextAlignment="Center"/>
                                <TextBlock Text="x"/>
                                <TextBlock Text="{Binding PriceWithDiscount, StringFormat={}{0:N0} ₽}" Width="80"/>
                                <TextBlock Text="=" Width="20" TextAlignment="Center"/>
                                <TextBlock Text="{Binding TotalPrice, StringFormat={}{0:N0} ₽}" FontWeight="Bold"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5">
                    <TextBlock Text="Итого:" FontWeight="Bold" FontSize="14" Margin="0,0,10,0"/>
                    <TextBlock x:Name="txtTotal" FontWeight="Bold" FontSize="14" Foreground="Green"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
            <Button x:Name="btnConfirm" Content="Подтвердить заказ" Width="150" Height="40" 
                    Background="#00FA9A" FontWeight="Bold" Margin="0,0,10,0" Click="btnConfirm_Click"/>
            <Button x:Name="btnCancel" Content="Отмена" Width="120" Height="40" 
                    Background="#7FFF00" Click="btnCancel_Click"/>
        </StackPanel>

        <TextBlock Grid.Row="6" x:Name="txtStatus" Foreground="Red" 
                   HorizontalAlignment="Center" Margin="0,10"/>
    </Grid>
</Window>