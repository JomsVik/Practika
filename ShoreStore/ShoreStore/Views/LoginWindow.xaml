<Window x:Class="ShoeStore.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему" Height="300" Width="350"
        WindowStartupLocation="CenterScreen"
        FontFamily="Times New Roman">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Авторизация" FontSize="20" 
                   FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Логин:" Margin="0,0,0,5"/>
            <TextBox x:Name="txtLogin" Height="25"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,20">
            <TextBlock Text="Пароль:" Margin="0,0,0,5"/>
            <PasswordBox x:Name="txtPassword" Height="25"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="btnLogin" Content="Войти" Width="80" Height="30" 
                    Background="#00FA9A" Margin="0,0,10,0" Click="btnLogin_Click"/>
            <Button x:Name="btnGuest" Content="Гость" Width="80" Height="30" 
                    Background="#7FFF00" Click="btnGuest_Click"/>
        </StackPanel>

        <TextBlock Grid.Row="4" x:Name="txtStatus" Foreground="Red" 
                   HorizontalAlignment="Center" Margin="0,10"/>
    </Grid>
</Window>