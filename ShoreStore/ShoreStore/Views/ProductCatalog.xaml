<Page x:Class="ShoeStore.Views.ProductCatalog"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Каталог товаров" Background="White"
      FontFamily="Times New Roman">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Каталог товаров" FontSize="20" 
                   FontWeight="Bold" Margin="0,0,0,10"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="itemsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="Gray" BorderThickness="1" 
                                CornerRadius="5" Padding="10" Margin="5"
                                Width="220">
                            <StackPanel>
                                <!-- ИЗОБРАЖЕНИЕ - используем Image, а не TextBlock -->
                                <Border Background="#F0F0F0" Height="120" Margin="0,0,0,5">
                                    <Image Source="{Binding ImagePath}" 
                                           Stretch="Uniform" 
                                           MaxHeight="110"
                                           VerticalAlignment="Center"/>
                                </Border>

                                <!-- Артикул -->
                                <TextBlock Text="{Binding Article}" 
                                           FontSize="10" Foreground="Gray"/>

                                <!-- Название -->
                                <TextBlock Text="{Binding Name}" 
                                           FontWeight="Bold" FontSize="14"
                                           TextWrapping="Wrap"/>

                                <!-- Категория -->
                                <TextBlock Text="{Binding Category}" 
                                           FontSize="11" Margin="0,2"/>

                                <!-- Цена -->
                                <TextBlock>
                                    <Run Text="Цена:" FontWeight="Bold"/>
                                    <Run Text="{Binding Price, StringFormat={}{0:N0} ₽}"/>
                                </TextBlock>

                                <!-- Скидка -->
                                <TextBlock>
                                    <Run Text="Скидка:" FontWeight="Bold"/>
                                    <Run Text="{Binding Discount}"/>
                                    <Run Text="%"/>
                                </TextBlock>

                                <!-- Наличие -->
                                <TextBlock Margin="0,5">
                                    <Run Text="В наличии:" FontWeight="Bold"/>
                                    <Run Text="{Binding Quantity}"/>
                                    <Run Text="шт."/>
                                </TextBlock>

                                <!-- Производитель -->
                                <TextBlock Text="{Binding Manufacturer}" 
                                           FontSize="11" Foreground="Gray"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>