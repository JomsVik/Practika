<Page x:Class="ShoeStore.Views.ProductCatalog"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Каталог товаров" Background="White"
      FontFamily="Times New Roman">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Каталог товаров" FontSize="24" 
                   FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="itemsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="Gray" BorderThickness="1" 
                                CornerRadius="5" Padding="10" Margin="5"
                                Width="220" Background="White"
                                Cursor="Hand" MouseLeftButtonUp="Product_MouseLeftButtonUp"
                                Tag="{Binding Id}">
                            <StackPanel>
                                <Border Background="#F0F0F0" Height="120" Margin="0,0,0,5">
                                    <Image Source="{Binding ImagePath}" 
                                           Stretch="Uniform" MaxHeight="110"/>
                                </Border>

                                <TextBlock Text="{Binding Article}" FontSize="10" Foreground="Gray"/>
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Category}" FontSize="11" Margin="0,2"/>

                                <TextBlock>
                                    <Run Text="Цена:" FontWeight="Bold"/>
                                    <Run Text="{Binding Price, StringFormat={}{0:N0} ₽}"/>
                                </TextBlock>

                                <TextBlock Margin="0,2">
                                    <Run Text="Скидка:" FontWeight="Bold"/>
                                    <Run Text="{Binding Discount}"/>
                                    <Run Text="%"/>
                                </TextBlock>

                                <TextBlock Margin="0,5">
                                    <Run Text="В наличии:" FontWeight="Bold"/>
                                    <Run Text="{Binding Quantity}"/>
                                    <Run Text="шт."/>
                                </TextBlock>

                                <TextBlock Text="{Binding Manufacturer}" FontSize="11" Foreground="Gray"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>