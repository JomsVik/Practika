<Page x:Class="ShoeStore.Views.ProductCatalog"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Каталог товаров" Background="White"
      FontFamily="Times New Roman">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Каталог товаров" FontSize="18" 
                   FontWeight="Bold" Margin="0,0,0,10"/>

        <ListBox Grid.Row="1" x:Name="listProducts">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Gray" BorderThickness="1" 
                            CornerRadius="5" Padding="10" Margin="5">
                        <StackPanel>
                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="14"/>
                            <TextBlock Text="{Binding Article}" Foreground="Gray"/>
                            <TextBlock Text="{Binding Category}" Margin="0,5"/>
                            <TextBlock Text="{Binding Price, StringFormat={}{0:N0} ₽}" 
                                       Foreground="Green" FontSize="16"/>
                            <TextBlock Text="{Binding Quantity, StringFormat=В наличии: {0} шт.}"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Page>