<Window x:Class="ShoeStore.Views.UserOrdersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ShoeStore.Converters"
        Title="Мои заказы" Height="500" Width="800"
        WindowStartupLocation="CenterOwner"
        FontFamily="Times New Roman"
        Background="White"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize">

    <Window.Resources>
        <local:StatusColorConverter x:Key="StatusColorConverter"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Мои заказы" FontSize="24" 
                   FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="listOrders">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="Gray" BorderThickness="1" 
                                CornerRadius="5" Padding="15" Margin="5"
                                Background="White">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Номер заказа:" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding OrderNumber}" FontSize="14" Foreground="Blue" TextWrapping="Wrap"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="20,0,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Дата: " FontWeight="Bold" Width="50"/>
                                        <TextBlock Text="{Binding OrderDate, StringFormat={}{0:dd.MM.yyyy HH:mm}}"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,5">
                                        <TextBlock Text="Статус: " FontWeight="Bold" Width="50"/>
                                        <TextBlock Text="{Binding Status}" 
                                                   Foreground="{Binding Status, Converter={StaticResource StatusColorConverter}}"
                                                   FontWeight="Bold"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Сумма: " FontWeight="Bold" Width="50"/>
                                        <TextBlock Text="{Binding TotalAmount, StringFormat={}{0:N0} ₽}" 
                                                   Foreground="Green" FontWeight="Bold"/>
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,5">
                                        <TextBlock Text="Код: " FontWeight="Bold" Width="50"/>
                                        <TextBlock Text="{Binding PickupCode}"/>
                                    </StackPanel>

                                    <Button Content="Подробнее" Width="100" Height="25" 
                                            Background="#00FA9A" Margin="0,5"
                                            Click="ViewOrderDetails_Click" Tag="{Binding Id}"
                                            HorizontalAlignment="Left"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20">
            <Button x:Name="btnClose" Content="Закрыть" Width="100" Height="35" 
                    Background="#7FFF00" FontSize="14" Click="btnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>