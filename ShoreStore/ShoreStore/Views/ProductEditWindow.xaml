<Window x:Class="ShoeStore.Views.ProductEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование товара" Height="600" Width="500"
        WindowStartupLocation="CenterOwner"
        FontFamily="Times New Roman"
        Background="White"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="txtTitle" Text="Добавление товара" FontSize="24" 
                   FontWeight="Bold" Margin="0,0,0,20" HorizontalAlignment="Center"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,0,20">
                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Артикул:" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtArticle" Height="35" Padding="5" FontSize="14"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Наименование товара:" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtName" Height="35" Padding="5" FontSize="14"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Единица измерения:" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtUnit" Height="35" Padding="5" FontSize="14" Text="шт."/>
                </StackPanel>

                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Цена:" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtPrice" Height="35" Padding="5" FontSize="14"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Поставщик:" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtSupplier" Height="35" Padding="5" FontSize="14"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Производитель:" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtManufacturer" Height="35" Padding="5" FontSize="14"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Категория:" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="cmbCategory" Height="35" FontSize="14" IsEditable="True"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Скидка (%):" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtDiscount" Height="35" Padding="5" FontSize="14" Text="0"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Количество на складе:" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtQuantity" Height="35" Padding="5" FontSize="14" Text="0"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Описание:" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtDescription" Height="80" Padding="5" FontSize="14" 
                             TextWrapping="Wrap" AcceptsReturn="True"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,15">
                    <TextBlock Text="Изображение:" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtImageUrl" Height="35" Padding="5" FontSize="14"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
            <Button x:Name="btnSave" Content="Сохранить" Width="120" Height="40" 
                    Background="#00FA9A" FontWeight="Bold" FontSize="14"
                    Margin="0,0,10,0" Click="btnSave_Click"/>
            <Button x:Name="btnCancel" Content="Отмена" Width="120" Height="40" 
                    Background="#7FFF00" FontSize="14" Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>